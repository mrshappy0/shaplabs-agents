# OpenAI API key for accessing OpenAI services (e.g., GPT-4)
OPENAI_API_KEY=

# Path to mcp-proxy binary for connecting to MCP servers
MCP_PROXY_PATH=

# Home Assistant MCP API endpoint URL
HOME_ASSISTANT_MCP_URL=

# Long-lived access token for Home Assistant (Authorization: Bearer ...)
HOME_ASSISTANT_ACCESS_TOKEN=