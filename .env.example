# ── Environment Variables ─────────────────────────────────────────────────────
#
# Development: copy to .env at the project root and fill in values.
#
# Unraid Docker deployment: place the filled-in .env file alongside
# docker-compose.yml in the Compose Manager project directory:
#   /boot/config/plugins/compose.manager/projects/mastra-app/.env
#
# DATABASE_URL, DISCORD_PENDING_PATH, and INNGEST_BASE_URL are set
# automatically by docker-compose.yml — do not override them here.
# ─────────────────────────────────────────────────────────────────────────────

# OpenAI API key for accessing OpenAI services (e.g., GPT-4)
OPENAI_API_KEY=

# Path to mcp-proxy binary for connecting to MCP servers
MCP_PROXY_PATH=

# Home Assistant MCP API endpoint URL
HOME_ASSISTANT_MCP_URL=

# Long-lived access token for Home Assistant (Authorization: Bearer ...)
HOME_ASSISTANT_ACCESS_TOKEN=

# GitHub personal access token (optional, raises API rate limit from 60 to 5000 req/hr)
# Create at: https://github.com/settings/tokens — no scopes needed for public repos
GITHUB_TOKEN=

# Unraid GraphQL API endpoint (e.g. http://unraid.local/graphql or http://<tailscale-ip>/graphql)
UNRAID_API_URL=

# Unraid API key — create at Settings → Management Access → API Keys
UNRAID_API_KEY=

# Docker Hub credentials (optional, prevents 401 Unauthorized on manifest fetches)
# Create a free access token at: https://hub.docker.com/settings/security
DOCKERHUB_USERNAME=
DOCKERHUB_TOKEN=

# Discord Bot — replaces the old webhook URL
# Create a bot at: https://discord.com/developers/applications
#   General Information → copy Application ID and Public Key
#   Bot → Reset Token → copy token; enable Message Content Intent
#   OAuth2 → URL Generator → bot scope → Send Messages, Use Slash Commands → invite to server
# JWT secret for Mastra auth — protects all /api/* routes except Discord and Inngest.
# Generate with: openssl rand -hex 32
MASTRA_JWT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_APP_ID=
DISCORD_PUBLIC_KEY=
DISCORD_CHANNEL_ID=

# Your Discord server ID — right-click server name → Copy Server ID (requires Developer Mode)
# Used when registering slash commands with register-discord-commands.ts
DISCORD_GUILD_ID=